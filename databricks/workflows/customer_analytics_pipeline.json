{
  "name": "customer_analytics_etl_daily",
  "email_notifications": {
    "on_failure": ["data-engineering@company.com"],
    "no_alert_for_skipped_runs": true
  },
  "schedule": {
    "quartz_cron_expression": "0 0 6 * * ?",
    "timezone_id": "America/New_York",
    "pause_status": "PAUSED"
  },
  "max_concurrent_runs": 1,
  "tasks": [
    {
      "task_key": "initialize_environment",
      "notebook_task": {
        "notebook_path": "/Repos/customer-analytics-etl-databricks/notebooks/00_setup/00_initialize_environment",
        "base_parameters": {
          "storage_account": "devdatalake",
          "catalog_name": "customer_analytics"
        }
      },
      "job_cluster_key": "etl_cluster"
    },
    {
      "task_key": "bronze_ingest_customers",
      "depends_on": [{"task_key": "initialize_environment"}],
      "notebook_task": {
        "notebook_path": "/Repos/customer-analytics-etl-databricks/notebooks/01_bronze/01_ingest_customers"
      },
      "job_cluster_key": "etl_cluster"
    },
    {
      "task_key": "bronze_ingest_transactions",
      "depends_on": [{"task_key": "initialize_environment"}],
      "notebook_task": {
        "notebook_path": "/Repos/customer-analytics-etl-databricks/notebooks/01_bronze/02_ingest_transactions"
      },
      "job_cluster_key": "etl_cluster"
    },
    {
      "task_key": "bronze_ingest_activity",
      "depends_on": [{"task_key": "initialize_environment"}],
      "notebook_task": {
        "notebook_path": "/Repos/customer-analytics-etl-databricks/notebooks/01_bronze/03_ingest_activity_logs"
      },
      "job_cluster_key": "etl_cluster"
    },
    {
      "task_key": "silver_transform_customers",
      "depends_on": [{"task_key": "bronze_ingest_customers"}],
      "notebook_task": {
        "notebook_path": "/Repos/customer-analytics-etl-databricks/notebooks/02_silver/01_transform_customers"
      },
      "job_cluster_key": "etl_cluster"
    },
    {
      "task_key": "silver_transform_transactions",
      "depends_on": [{"task_key": "bronze_ingest_transactions"}],
      "notebook_task": {
        "notebook_path": "/Repos/customer-analytics-etl-databricks/notebooks/02_silver/02_transform_transactions"
      },
      "job_cluster_key": "etl_cluster"
    },
    {
      "task_key": "silver_transform_activity",
      "depends_on": [{"task_key": "bronze_ingest_activity"}],
      "notebook_task": {
        "notebook_path": "/Repos/customer-analytics-etl-databricks/notebooks/02_silver/03_transform_activity_logs"
      },
      "job_cluster_key": "etl_cluster"
    },
    {
      "task_key": "gold_customer_lifetime_value",
      "depends_on": [
        {"task_key": "silver_transform_customers"},
        {"task_key": "silver_transform_transactions"}
      ],
      "notebook_task": {
        "notebook_path": "/Repos/customer-analytics-etl-databricks/notebooks/03_gold/01_customer_lifetime_value"
      },
      "job_cluster_key": "etl_cluster"
    },
    {
      "task_key": "gold_customer_segmentation",
      "depends_on": [{"task_key": "gold_customer_lifetime_value"}],
      "notebook_task": {
        "notebook_path": "/Repos/customer-analytics-etl-databricks/notebooks/03_gold/02_customer_segmentation"
      },
      "job_cluster_key": "etl_cluster"
    },
    {
      "task_key": "gold_revenue_metrics",
      "depends_on": [
        {"task_key": "silver_transform_customers"},
        {"task_key": "silver_transform_transactions"}
      ],
      "notebook_task": {
        "notebook_path": "/Repos/customer-analytics-etl-databricks/notebooks/03_gold/03_revenue_metrics"
      },
      "job_cluster_key": "etl_cluster"
    },
    {
      "task_key": "gold_activity_scores",
      "depends_on": [
        {"task_key": "silver_transform_customers"},
        {"task_key": "silver_transform_activity"}
      ],
      "notebook_task": {
        "notebook_path": "/Repos/customer-analytics-etl-databricks/notebooks/03_gold/04_activity_scores"
      },
      "job_cluster_key": "etl_cluster"
    },
    {
      "task_key": "delta_maintenance",
      "depends_on": [
        {"task_key": "gold_customer_segmentation"},
        {"task_key": "gold_revenue_metrics"},
        {"task_key": "gold_activity_scores"}
      ],
      "notebook_task": {
        "notebook_path": "/Repos/customer-analytics-etl-databricks/notebooks/05_maintenance/01_delta_optimize_vacuum"
      },
      "job_cluster_key": "etl_cluster"
    },
    {
      "task_key": "data_quality_dashboard",
      "depends_on": [{"task_key": "delta_maintenance"}],
      "notebook_task": {
        "notebook_path": "/Repos/customer-analytics-etl-databricks/notebooks/05_maintenance/02_data_quality_dashboard"
      },
      "job_cluster_key": "etl_cluster"
    }
  ],
  "job_clusters": [
    {
      "job_cluster_key": "etl_cluster",
      "new_cluster": {
        "spark_version": "14.3.x-scala2.12",
        "node_type_id": "Standard_DS3_v2",
        "num_workers": 2,
        "spark_conf": {
          "spark.sql.extensions": "io.delta.sql.DeltaSparkSessionExtension",
          "spark.sql.catalog.spark_catalog": "org.apache.spark.sql.delta.catalog.DeltaCatalog",
          "spark.databricks.delta.optimizeWrite.enabled": "true",
          "spark.databricks.delta.autoCompact.enabled": "true"
        },
        "azure_attributes": {
          "availability": "ON_DEMAND_AZURE"
        }
      }
    }
  ],
  "tags": {
    "project": "customer_analytics",
    "team": "data_engineering",
    "environment": "dev"
  }
}
